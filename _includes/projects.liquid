<div class="col">
  <div class="project-card h-100">
    <a href="{% if project.redirect %}{{ project.redirect }}{% else %}{{ project.url | relative_url }}{% endif %}" class="project-link">
      <div class="card h-100 hoverable enhanced-project-card">
        {% if project.img %}
          <div class="card-img-container">
            {%
              include figure.liquid
              loading="eager"
              path=project.img
              sizes = "350px"
              alt="project thumbnail"
              class="card-img-top project-thumbnail"
            %}
            <div class="img-overlay">
              <i class="fas fa-eye view-icon"></i>
            </div>
          </div>
        {% endif %}
        
        <div class="card-body d-flex flex-column">
          <div class="project-meta mb-2">
            {% if project.category %}
              <span class="category-badge">
                {% if project.category == "work" %}
                  <i class="fas fa-briefcase"></i> Professional
                {% elsif project.category == "fun" %}
                  <i class="fas fa-lightbulb"></i> Experimental
                {% else %}
                  <i class="fas fa-folder"></i> {{ project.category | capitalize }}
                {% endif %}
              </span>
            {% endif %}
            {% if project.importance %}
              <span class="importance-badge">
                {% assign stars = project.importance %}
                {% for i in (1..stars) %}
                  <i class="fas fa-star"></i>
                {% endfor %}
              </span>
            {% endif %}
          </div>
          
          <h3 class="card-title project-title">{{ project.title }}</h3>
          <p class="card-text project-description flex-grow-1">{{ project.description }}</p>
          
          {% if project.technologies %}
            <div class="technologies-section mb-3">
              <div class="tech-tags">
                {% assign tech_array = project.technologies | split: "," %}
                {% for tech in tech_array limit: 3 %}
                  <span class="tech-tag">{{ tech | strip }}</span>
                {% endfor %}
                {% if tech_array.size > 3 %}
                  <span class="tech-tag-more">+{{ tech_array.size | minus: 3 }} more</span>
                {% endif %}
              </div>
            </div>
          {% endif %}
          
          <div class="project-footer mt-auto">
            <div class="project-actions">
              {% if project.github %}
                <div class="action-item">
                  <a href="{{ project.github }}" class="action-link" target="_blank" onclick="event.stopPropagation();">
                    <i class="fa-brands fa-github"></i>
                    <span>Code</span>
                  </a>
                  {% if project.github_stars %}
                    <span class="stars-count" data-toggle="tooltip" title="GitHub Stars">
                      <i class="fa-solid fa-star"></i>
                      <span id="{{ project.github_stars }}-stars">{{ project.github_stars }}</span>
                    </span>
                  {% endif %}
                </div>
              {% endif %}
              
              {% if project.demo %}
                <div class="action-item">
                  <a href="{{ project.demo }}" class="action-link" target="_blank" onclick="event.stopPropagation();">
                    <i class="fas fa-external-link-alt"></i>
                    <span>Demo</span>
                  </a>
                </div>
              {% endif %}
              
              {% if project.paper %}
                <div class="action-item">
                  <a href="{{ project.paper }}" class="action-link" target="_blank" onclick="event.stopPropagation();">
                    <i class="fas fa-file-pdf"></i>
                    <span>Paper</span>
                  </a>
                </div>
              {% endif %}
            </div>
            
            {% if project.status %}
              <div class="project-status">
                {% if project.status == "completed" %}
                  <span class="status-badge status-completed">
                    <i class="fas fa-check-circle"></i> Completed
                  </span>
                {% elsif project.status == "ongoing" %}
                  <span class="status-badge status-ongoing">
                    <i class="fas fa-clock"></i> Ongoing
                  </span>
                {% elsif project.status == "planning" %}
                  <span class="status-badge status-planning">
                    <i class="fas fa-lightbulb"></i> Planning
                  </span>
                {% endif %}
              </div>
            {% endif %}
          </div>
        </div>
      </div>
    </a>
  </div>
</div>

<style>
/* Enhanced Project Card Styling */
.project-card {
  margin-bottom: 2rem;
  transition: all 0.3s ease;
}

.enhanced-project-card {
  border: none;
  border-radius: 1rem;
  overflow: hidden;
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  background: linear-gradient(135deg, #ffffff 0%, #f8f9fa 100%);
  position: relative;
}

.enhanced-project-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 4px;
  background: linear-gradient(90deg, #667eea 0%, #764ba2 100%);
  transform: scaleX(0);
  transition: transform 0.3s ease;
  z-index: 1;
}

.enhanced-project-card:hover::before {
  transform: scaleX(1);
}

.enhanced-project-card:hover {
  transform: translateY(-8px);
  box-shadow: 0 15px 40px rgba(0, 0, 0, 0.15);
}

.project-link {
  text-decoration: none;
  color: inherit;
}

.project-link:hover {
  text-decoration: none;
  color: inherit;
}

/* Image Container */
.card-img-container {
  position: relative;
  overflow: hidden;
  height: 200px;
}

.project-thumbnail {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: all 0.4s ease;
}

.enhanced-project-card:hover .project-thumbnail {
  transform: scale(1.05);
}

.img-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.8), rgba(118, 75, 162, 0.8));
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transition: all 0.3s ease;
}

.enhanced-project-card:hover .img-overlay {
  opacity: 1;
}

.view-icon {
  color: white;
  font-size: 2rem;
  transform: scale(0.8);
  transition: all 0.3s ease;
}

.enhanced-project-card:hover .view-icon {
  transform: scale(1);
}

/* Project Meta */
.project-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: 0.5rem;
}

.category-badge {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  padding: 0.3rem 0.8rem;
  border-radius: 1rem;
  font-size: 0.8rem;
  font-weight: 600;
  display: inline-flex;
  align-items: center;
  gap: 0.4rem;
}

.importance-badge {
  color: #ffc107;
  font-size: 0.9rem;
}

/* Project Title */
.project-title {
  font-size: 1.3rem;
  font-weight: 700;
  color: #2c3e50;
  margin-bottom: 0.75rem;
  line-height: 1.3;
  transition: color 0.3s ease;
}

.enhanced-project-card:hover .project-title {
  color: #667eea;
}

/* Project Description */
.project-description {
  color: #6c757d;
  line-height: 1.6;
  margin-bottom: 1rem;
  font-size: 0.95rem;
}

/* Technologies Section */
.technologies-section {
  border-top: 1px solid #e9ecef;
  padding-top: 1rem;
}

.tech-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 0.4rem;
}

.tech-tag {
  background: #e9ecef;
  color: #495057;
  padding: 0.25rem 0.6rem;
  border-radius: 0.8rem;
  font-size: 0.75rem;
  font-weight: 600;
  transition: all 0.3s ease;
}

.tech-tag:hover {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  transform: translateY(-1px);
}

.tech-tag-more {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  padding: 0.25rem 0.6rem;
  border-radius: 0.8rem;
  font-size: 0.75rem;
  font-weight: 600;
}

/* Project Footer */
.project-footer {
  border-top: 1px solid #e9ecef;
  padding-top: 1rem;
}

.project-actions {
  display: flex;
  gap: 1rem;
  margin-bottom: 0.75rem;
  flex-wrap: wrap;
}

.action-item {
  display: flex;
  align-items: center;
  gap: 0.5rem;
}

.action-link {
  display: inline-flex;
  align-items: center;
  gap: 0.4rem;
  color: #667eea;
  text-decoration: none;
  font-weight: 600;
  font-size: 0.9rem;
  padding: 0.4rem 0.8rem;
  border-radius: 1rem;
  transition: all 0.3s ease;
  border: 2px solid transparent;
}

.action-link:hover {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  text-decoration: none;
  transform: translateY(-2px);
  box-shadow: 0 4px 12px rgba(102, 126, 234, 0.3);
}

.stars-count {
  color: #ffc107;
  font-size: 0.8rem;
  display: inline-flex;
  align-items: center;
  gap: 0.2rem;
}

/* Project Status */
.project-status {
  display: flex;
  justify-content: flex-end;
}

.status-badge {
  padding: 0.3rem 0.8rem;
  border-radius: 1rem;
  font-size: 0.8rem;
  font-weight: 600;
  display: inline-flex;
  align-items: center;
  gap: 0.4rem;
}

.status-completed {
  background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
  color: white;
}

.status-ongoing {
  background: linear-gradient(135deg, #ff9a56 0%, #ffad56 100%);
  color: white;
}

.status-planning {
  background: linear-gradient(135deg, #3b82f6 0%, #06b6d4 100%);
  color: white;
}

/* Responsive Design */
@media (max-width: 768px) {
  .card-img-container {
    height: 180px;
  }
  
  .project-title {
    font-size: 1.1rem;
  }
  
  .project-actions {
    gap: 0.5rem;
  }
  
  .action-link {
    font-size: 0.8rem;
    padding: 0.3rem 0.6rem;
  }
}

/* Animation for project cards */
@keyframes projectCardFadeIn {
  from {
    opacity: 0;
    transform: translateY(20px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.project-card {
  animation: projectCardFadeIn 0.6s ease-out;
}
</style>
